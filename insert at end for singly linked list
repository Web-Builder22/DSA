#include<iostream>
using namespace std;

class Node{
    public:
    int data;
    Node *next;
    Node(int val){
        data=val;
    }
};
class Linklist{
public:
    Node *head;
    Linklist(){
        head=NULL;
    }
    void insertAtEnd(int val){
        Node *newNode=new Node(val);
          if(head == NULL){    
            head = newNode;
            return;
        }
        
    Node *temp=head;
    while(temp->next!=NULL){
        temp=temp->next;
    }
    temp->next=newNode;
    }
    void display(){
        Node *temp=head;
        while(temp!=NULL){
            cout<<temp->data;
            temp=temp->next;
            
        }
    }
};
int main(){
    Linklist l;
    l.insertAtEnd(10);
    l.insertAtEnd(20);
    l.insertAtEnd(30);
    l.display();
}
